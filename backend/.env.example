# Backend env example — copy to backend/.env and fill values
BACKEND_PORT=8000

# Supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Frontend redirect URLs used by backend for verification/reset
FRONTEND_VERIFY_URL=http://localhost:5173/verify
FRONTEND_RESET_URL=http://localhost:5173/reset-password

# Optional: SMTP settings for sending emails
# Para habilitar correo real, pon ENABLE_DEV_EMAILS=false y completa los datos SMTP.
# Para pruebas locales sin SMTP real, deja los campos SMTP vacíos y pon ENABLE_DEV_EMAILS=true.
ENABLE_DEV_EMAILS=false

# Gmail (requiere App Password si tienes verificación en dos pasos activada)
# MAIL_HOST=smtp.gmail.com
# MAIL_PORT=587
# MAIL_SECURE=false
# MAIL_USER=tu-correo@gmail.com
# MAIL_PASS=tu-app-password
# MAIL_FROM=Tu Nombre <tu-correo@gmail.com>

# Outlook / Microsoft 365
# MAIL_HOST=smtp.office365.com
# MAIL_PORT=587
# MAIL_SECURE=false
# MAIL_USER=tu-correo@outlook.com
# MAIL_PASS=tu-app-password
# MAIL_FROM=Tu Nombre <tu-correo@outlook.com>

MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USER=your-smtp-user@example.com
MAIL_PASS=your-smtp-password
MAIL_FROM=swes-noreply@yourdomain.com
MAIL_SECURE=false
MAIL_TLS_REJECT_UNAUTHORIZED=true
# Si usas port 465, pon MAIL_SECURE=true.
# Si tu servidor SMTP usa certificado autofirmado, establece MAIL_TLS_REJECT_UNAUTHORIZED=false.
# También soporta nombres de variable SMTP_HOST, SMTP_PORT, SMTP_USER, SMTP_PASSWORD y MAIL_FROM_ADDRESS.

# Note: Google OAuth credentials should be configured in Supabase Console (Authentication → Settings → External OAuth Providers → Google)

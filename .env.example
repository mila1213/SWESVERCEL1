# Ejemplo de configuración de entorno para el proyecto SWES.
# No incluyas este archivo en producción, solo copia los valores y crea tus propios .env.

# Backend (usar en backend/.env)
PORT=8000
FIREBASE_API_KEY=tu_api_key
FRONTEND_VERIFY_URL=http://localhost:5173/verify

# Frontend (usar en frontend/.env)
VITE_FIREBASE_API_KEY=tu_api_key
VITE_FIREBASE_AUTH_DOMAIN=tu_dominio
VITE_FIREBASE_PROJECT_ID=tu_proyecto
VITE_FIREBASE_STORAGE_BUCKET=tu_bucket
VITE_FIREBASE_MESSAGING_SENDER_ID=tu_messaging_sender_id
VITE_FIREBASE_APP_ID=tu_app_id
VITE_FIREBASE_MEASUREMENT_ID=tu_measurement_id
VITE_BACKEND_URL=http://localhost:8000/api
